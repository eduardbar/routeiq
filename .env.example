# ============================================================
# RouteIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Data Source ──────────────────────────────────────────────
# Which adapter to use: "mock" | "openrouter" | "litellm"
# Default is "mock" — no keys needed for demos.
NEXT_PUBLIC_DATA_SOURCE=mock

# ── OpenRouter ───────────────────────────────────────────────
# Standard API key (sk-or-v1-...)
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# ── LiteLLM (coming in Day 7) ────────────────────────────────
# Base URL of your LiteLLM proxy instance
LITELLM_BASE_URL=http://localhost:4000
# Master key for the LiteLLM management API
LITELLM_MASTER_KEY=
